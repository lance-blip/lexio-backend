OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Primary model — DeepSeek V4 Pro (legal Q&A, scenario analysis)
DEFAULT_MODEL=deepseek/deepseek-v4-pro

# Fallback model
FALLBACK_MODEL=google/gemini-2.0-flash-001

# Multimodal model — Google Gemma 4 31B (image analysis, document processing)
MULTIMODAL_MODEL=google/gemma-4-31b-it

API_SECRET_KEY=your_random_secret_key_here_change_this
RATE_LIMIT_FREE=20/hour
RATE_LIMIT_PREMIUM=1000/hour
ALLOWED_ORIGINS=*
LOG_LEVEL=INFO